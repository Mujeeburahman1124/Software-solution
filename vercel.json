{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "nodeVersion": "18.x",
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL connection string",
      "required": true
    },
    "NEXTAUTH_SECRET": {
      "description": "NextAuth secret key",
      "required": true
    },
    "NEXTAUTH_URL": {
      "description": "Application URL",
      "required": true
    },
    "JWT_SECRET": {
      "description": "JWT secret for token signing",
      "required": true
    },
    "NODE_ENV": {
      "value": "production"
    }
  }
}
